<?xml version="1.0" encoding="utf-8"?>
<!--firstviewlayout.xml-->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <!-- view Room -->
    <com.example.mygame.views.MaskClickableImageView
        android:id="@+id/regionMap"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:scaleType="fitCenter"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- RIGHT PANEL as ConstraintLayout -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/rightPanel"
        android:layout_width="wrap_content"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:background="@drawable/dialog_background"
        android:visibility="visible"
        android:clickable="true"
        android:focusable="true"
        android:elevation="12dp">

        <!-- Overlay image: match panel width, keep aspect ratio -->
        <ImageView
            android:id="@+id/overlay"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            android:visibility="gone"
            android:adjustViewBounds="true"
            android:scaleType="fitCenter"
            android:src="@drawable/bard"
            android:layout_marginBottom="8dp" />

        <LinearLayout
            android:id="@+id/topBar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <ImageButton
                android:id="@+id/endTurnButton"
                android:layout_width="50dp"
                android:layout_height="50dp"
                android:background="@android:color/transparent"
                android:contentDescription="@string/end_turn"
                android:scaleType="centerInside"
                android:minWidth="48dp"
                android:minHeight="48dp"
                app:srcCompat="@drawable/next_turn"/>

            <ImageButton
                android:id="@+id/skipSeveralTurnsButton"
                android:layout_width="50dp"
                android:layout_height="50dp"
                android:background="@android:color/transparent"
                android:contentDescription="@string/skip_several_turns"
                android:scaleType="centerInside"
                android:minWidth="48dp"
                android:minHeight="48dp"
                app:srcCompat="@drawable/skip_few_turns"/>

            <ImageButton
                android:id="@+id/returnToMainMenuButton"
                android:layout_width="50dp"
                android:layout_height="50dp"
                android:background="@android:color/transparent"
                android:contentDescription="@string/return_to_main_menu"
                android:scaleType="centerInside"
                android:minWidth="48dp"
                android:minHeight="48dp"
                app:srcCompat="@drawable/back_to_main_menu"/>
        </LinearLayout>



    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>