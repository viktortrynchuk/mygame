<?xml version="1.0" encoding="utf-8"?>
<!-- res/layout/activity_main.xml -->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/hunt">
    <!--View for the hunt-->
    <ImageButton
        android:id="@+id/returnToMainMenuButton7"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:scaleType="centerInside"
        android:contentDescription="@string/return_to_main_menu"
        android:background="@android:color/transparent"
        app:srcCompat="@drawable/back_to_main_menu"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="16dp"
        android:layout_marginEnd="16dp" />

    <ImageButton
        android:id="@+id/returnToHomeButton7"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:scaleType="centerInside"
        android:contentDescription="@string/return_to_the_home"
        android:background="@android:color/transparent"
        app:srcCompat="@drawable/return_home_town"
        app:layout_constraintTop_toBottomOf="@id/returnToMainMenuButton7"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="12dp"
        android:layout_marginEnd="16dp" />
    <!-- Center button -->
    <Button
        android:id="@+id/joinHuntButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/join_the_hunt"
        android:backgroundTint="@color/black"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>